# Exploratory Data Analysis (EDA)
This notebook explores the dataset before using it in the AI Business Intelligence Assistant.

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Replace with your dataset file
df = pd.read_csv("dailyActivity_merged.csv")

# Quick look at the first 5 rows
df.head()

# Info about columns, types, missing values
df.info()

# Basic statistics
df.describe()

df.isnull().sum()

# Example: Histogram of steps
plt.figure(figsize=(10,5))
sns.histplot(df['TotalSteps'], bins=30, kde=True)
plt.title("Distribution of Total Steps")
plt.show()

# Example: Calories burned over days
plt.figure(figsize=(12,5))
sns.lineplot(x='ActivityDate', y='Calories', data=df)
plt.xticks(rotation=45)
plt.title("Calories Burned Over Time")
plt.show()

# Observations
- Average steps per day: ...
- Days with unusually high/low activity: ...
- Any patterns you notice: ...

plt.figure(figsize=(10,6))
sns.heatmap(df.corr(), annot=True, cmap='coolwarm')
plt.show()
